  "item": [
    {
      "name": "1 - User",
      "item": [
        {
          "name": "Create admin user",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Gerando um e-mail aleatório //",
                  "const numeroAleatorio = Math.floor(Math.random() * 100000);",
                  "const emailDinamico = `qa_admin_${numeroAleatorio}@testportfolio.com`;",
                  "",
                  "// Salvando o e-mail e a senha no environment //",
                  "pm.environment.set(\"adminEmail\", emailDinamico);",
                  "pm.environment.set(\"adminPassword\", \"senhaSegura123\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Teste 1: Valida o status code //",
                  "pm.test(\"Status code = 201\",",
                  "function ()",
                  "{",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "",
                  "// Teste 2: Valida a mensagem de sucesso //",
                  "pm.test(\"Mensagem = 'Sucesso'\",",
                  "function ()",
                  "{",
                  "    const resposta = pm.response.json();",
                  "    pm.expect(resposta.message).to.eql(\"Cadastro realizado com sucesso\");",
                  "});",
                  "",
                  "",
                  "// Teste 3: Valida se o User ID retornou e se salvamos //",
                  "pm.test(\"User ID criado e armazenado\",",
                  "function ()",
                  "{",
                  "    const resposta = pm.response.json();",
                  "    pm.expect(resposta).to.have.property(\"_id\");",
                  "    ",
                  "    pm.environment.set(\"adminId\", resposta._id);",
                  "});",
                  "",
                  "",
                  "// Teste 4: Valida a performance //",
                  "pm.test(\"Resposta > 500ms\",",
                  "function ()",
                  "{",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"QA Automation Administrator\",\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"administrador\": \"true\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/usuarios",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "usuarios"
              ]
            }
          },
          "response": []
        }
      ]
    },
